CONFIG_ENV=experimental.env

KERNEL_SOURCE=https://github.com/tem423/linux-android-msm-lenovo-p12
KERNEL_SOURCE_BRANCH=android16-base
KERNEL_CONFIG=vendor/tb371fc_defconfig
KERNEL_IMAGE_NAME=Image
ARCH=arm64
ADD_LOCALVERSION_TO_FILENAME=true
EXTRA_CMDS:HOSTCC=clang,LD=ld.lld,AR=llvm-ar,NM=llvm-nm,OBJCOPY=llvm-objcopy,OBJDUMP=llvm-objdump,STRIP=llvm-strip"

# Clang
## Custom
USE_CUSTOM_CLANG=true
CUSTOM_CLANG_SOURCE=https://github.com/ZyCromerZ/Clang/releases/download/16.0.6-20260510-release/Clang-16.0.6-20260510.tar.gz
CUSTOM_CLANG_BRANCH=main

### if your set USE CUSTOM CLANG to false than DO NOT CHANGE CUSTOM CMDS
CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-

## AOSP
CLANG_BRANCH=master
CLANG_VERSION=r547379

# GCC
ENABLE_GCC_ARM64=true
ENABLE_GCC_ARM32=false
USE_CUSTOM_GCC_64=false
CUSTOM_GCC_64_SOURCE=
CUSTOM_GCC_64_BRANCH=
CUSTOM_GCC_64_BIN=aarch64-linux-android-
USE_CUSTOM_GCC_32=false
CUSTOM_GCC_32_SOURCE=
CUSTOM_GCC_32_BRANCH=
CUSTOM_GCC_32_BIN=arm-linux-androideabi-

# KernelSU flags
ENABLE_KERNELSU=false
KERNELSU_TAG=b766b98513b5a7eb33bc1c4a76b5702bf1288f07
KSU_EXPECTED_SIZE=
KSU_EXPECTED_HASH=

# Configuration
DISABLE-LTO=false
DISABLE_CC_WERROR=false
ADD_KPROBES_CONFIG=false
ADD_OVERLAYFS_CONFIG=false
APPLY_KSU_PATCH=false

# AnyKernel3
## AnyKernel3 Custom
USE_CUSTOM_ANYKERNEL3=false
CUSTOM_ANYKERNEL3_SOURCE=
CUSTOM_ANYKERNEL3_BRANCH=

# Ccache
ENABLE_CCACHE=false

# DTBO image
NEED_DTBO=false

# Build boot images
BUILD_BOOT_IMG=true
SOURCE_BOOT_IMAGE=https://github.com/tem423/linux-android-msm-lenovo-p12/releases/download/originalboot/boot.img

# Addon Config
# We will add it by ourselves
IMPORT_DOCKER=false
Kernel_Version=4.19
Kernel_Extra_Version=4.19.325
Remove_Kernel_Validation=false
Remove_Warning=false
Docker_LXC_Patches=false
Remove_ANDROID_PARANOID_NETWORK=false
Add_Kali_Nethunter_Patches=false
Generate_Build_Config=false
Generate_Command=
